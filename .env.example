# Database
DATABASE_URL=postgres://heyloaf:devpassword@localhost:5432/heyloaf

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8083

# Auth
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_TOKEN_TTL_SECS=900
JWT_REFRESH_TOKEN_TTL_SECS=604800

# CORS
CORS_ORIGINS=http://localhost:3003

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

