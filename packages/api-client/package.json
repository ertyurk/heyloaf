{
  "name": "@heyloaf/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "gen": "openapi-typescript http://localhost:8083/api-docs/openapi.json -o src/schema.gen.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.5"
  },
  "devDependencies": {
    "openapi-typescript": "^7.6.1",
    "typescript": "^5.8.2"
  }
}
